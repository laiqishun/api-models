            "label": "- The total amount seller may be received = Base price * quantity + Shipping total − Estimated revenue deduction",
            "rows": [
              {
                "Fields": "`basePrice`",
                "Meaning": "One of the amounts that the seller can receive, representing the actual amount the seller gets for the sold item"
              },
              {
                "Fields": "`shippingAmountTotal`",
                "Meaning": "One of the amounts a seller can receive, representing the shipping fee income the seller gets from selling the item"
              },
              {
                "Fields": "`taxTotal`",
                "Meaning": "United States: Because Temu does not collect and pay taxes on behalf of the seller, the seller cannot receive this amount.Europe: In Europe, sellers report their own taxes, so they can receive this amount."
              },
              {
                "Fields": "`taxTotalAfterDiscount`",
                "Meaning": "For taxes, the discount on the order sales amount will affect the tax amount, so this field represents the total tax amount after the discount"
              },
              {
                "Fields": "`discountFromSeller`",
                "Meaning": "Discount amount from the seller"
              },
              {
                "Fields": "`discountFromTemu`",
                "Meaning": "The discount amount from Temu"
              },
              {
                "Fields": "`estimatedRevenue`",
                "Meaning": "The estimated total amount the seller can receive`estimatedRevenue`=`basePrice`+ `shippingAmountTotal`- `estimatedRevenueDeduction`"
              },
              {
                "Fields": "Amount actually paid by the consumer",
                "Meaning": "Amount actually paid by the consumer= `unitRetailPriceVatExcl` × `quantity`+ `taxTotal`+ `shippingAmountTotal`- `discountFromSeller`- `discountFromTemu`- `refundsTotal`"
              }
            ]
          }
        ],
