        "parameters": [
          {
            "$ref": "#/components/parameters/AccountIdHeaderOptional"
          },
          {
            "$ref": "#/components/parameters/ClientIdHeader"
          },
          {
            "$ref": "#/components/parameters/ManagerAccountIdHeaderOptional"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "examples": {
                "LocationIndexCreateRequestExample": {
                  "summary": "Create Location Index Request Example",
                  "value": {
                    "locationIndexes": [
                      {
                        "indexData": {
                          "directIndexValues": {
                            "values": [
                              {
                                "indexValue": 42,
                                "postalCode": "80202"
                              },
                              {
                                "indexValue": 72,
                                "postalCode": "80301"
                              },
