      "get": {
        "tags": [
          "customerFeedback"
        ],
        "description": "Retrieve a browse node's ten most positive and ten most negative review topics.",
        "operationId": "getBrowseNodeReviewTopics",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "browseNodeId",
            "in": "path",
            "description": "The ID of a browse node. A browse node is a named location in a browse tree that is used for navigation, product classification, and website content.",
            "required": true,
            "type": "string"
          },
          {
            "name": "marketplaceId",
            "in": "query",
            "description": "The MarketplaceId is the globally unique identifier of a marketplace, you can refer to the marketplaceId here : https://developer-docs.amazon.com/sp-api/docs/marketplace-ids.",
            "required": true,
            "type": "string"
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "The metric by which to sort the data in the response.",
            "required": true,
            "type": "string",
            "items": {
              "type": "string",
              "enum": [
                "MENTIONS",
                "STAR_RATING_IMPACT"
              ],
              "x-docgen-enum-table-extension": [
                {
                  "value": "MENTIONS",
                  "description": "The top positive and negative topics calculated by their occurrence percentage in customers reviews of the ASINs under the requested BrowseNode."
                },
                {
                  "value": "STAR_RATING_IMPACT",
                  "description": "The top positive and negative topics calculated by their impact towards the star rating of the products under the requested BrowseNode."
                }
              ]
            },
            "collectionFormat": "csv",
            "x-example": "MENTIONS"
