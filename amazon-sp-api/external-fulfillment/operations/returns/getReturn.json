          "enum": [
            "WITH_OTP",
            "WITHOUT_OTP"
          ],
          "x-docgen-enum-table-extension": [
            {
              "value": "WITH_OTP",
              "description": "The return package was delivered to the seller with OTP verification."
            },
            {
              "value": "WITHOUT_OTP",
              "description": "The return package was delivered to the seller without OTP verification."
            }
          ]
        },
