            "maxLength": 1024,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9-._ ]*$",
            "type": "string"
          },
          "type": "array"
        },
        "solution": {
          "description": "Shipping program for the option. Can be: `AMAZON_PARTNERED_CARRIER`, `USE_YOUR_OWN_CARRIER`.",
