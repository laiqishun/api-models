        },
        "districtOrCounty": {
          "description": "The district or county.",
          "maxLength": 50,
          "minLength": 1,
          "type": "string"
        },
        "email": {
          "description": "The email address.",
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "description": "The name of the individual who is the primary contact.",
          "maxLength": 50,
          "minLength": 1,
