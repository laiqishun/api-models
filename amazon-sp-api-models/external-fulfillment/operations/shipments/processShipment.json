      "properties": {
        "referenceId": {
          "description": "A unique identifier for every shipment rejection.",
          "type": "string"
        },
        "lineItems": {
          "description": "Details about the line items from the shipment that are being confirmed or rejected by the seller.",
          "type": "array",
          "minItems": 0,
          "items": {
