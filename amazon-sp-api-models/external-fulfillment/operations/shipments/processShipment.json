  "definitions": {
    "LineItemWithReason": {
      "description": "Information about the line item being confirmed or rejected and the reason for the rejection.",
      "type": "object",
      "properties": {
        "lineItem": {
          "$ref": "#/definitions/LineItem"
        },
        "reason": {
          "description": "The reason for the rejection of the line item.",
          "type": "string",
          "enum": [
            "OUT_OF_STOCK",
            "CUSTOMER_REQUESTED"
          ],
          "x-docgen-enum-table-extension": [
            {
              "value": "OUT_OF_STOCK",
              "description": "The item is out of stock."
            },
            {
              "value": "CUSTOMER_REQUESTED",
              "description": "The customer requested rejection."
            }
          ]
        }
      },
      "example": {
        "lineItem": {
          "id": "1",
          "quantity": 0
        },
        "reason": "OUT_OF_STOCK"
      },
      "required": [
        "lineItem"
      ]
    },
    "LineItem": {
      "description": "Information about the line item being confirmed or rejected.",
      "type": "object",
      "properties": {
        "id": {
          "description": "The identifier of the line item from the shipment that is being confirmed or rejected by the seller.",
          "type": "string"
        },
        "quantity": {
          "description": "The quantity of the line item.",
          "type": "integer"
        }
      },
      "example": {
        "id": "1",
        "quantity": 0
      },
      "required": [
        "id"
      ]
    },
